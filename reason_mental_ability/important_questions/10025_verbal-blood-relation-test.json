      "id": 1052452,
      "type": "VSA (Very Short Answer)",
      "question_text": "Answer the question based on the following information:\nA + B means A is the mother of B.\nA - B means A is the sister of B.\nA * B means A is the father of B.\nA {tex}\\pi{/tex} B means A is the brother of B.\nWhich of the following means that N is the maternal uncle of M?",
      "question_images": [],
      "options": [
        {
          "label": "A",
          "text": "N - Y + A {tex}\\pi{/tex} M",
          "is_correct": false,
          "option_images": []
        },
        {
          "label": "B",
          "text": "N {tex}\\pi{/tex} P - L + E - M",
          "is_correct": true,
          "option_images": []
        },
        {
          "label": "C",
          "text": "M - Y * P - N",
          "is_correct": false,
          "option_images": []
        },
        {
          "label": "D",
          "text": "N {tex}\\pi{/tex} C + F * M",
          "is_correct": false,
          "option_images": []
        }
      ],
      "correct_answer": "N {tex}\\pi{/tex} P - L + E - M",
      "correct_answer_label": "B",
      "correct_answer_images": [],
      "explanation_text": "Let us consider this option\nClearly, M's sister is E and E's mother is L.\nM's mother is L. L's sister is P.\nM's maternal aunt is P. P's brother is N.\nSo, N is maternal uncle of M.",
      "explanation_images": [
        "https://media-mycbseguide.s3.amazonaws.com/images/question_images/1673502900-9gmtc3.jpg"
      ]
    },
