{
  "cli": {
    "version": ">= 20.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_API_URL": "https://ai-teacher-app-jgzx.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_PUBLIC_API_URL": "https://ai-teacher-app-jgzx.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
