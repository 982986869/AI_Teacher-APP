        },
        {
          "question": "<p>How do the areas covered with concrete affect the availability of ground water?</p>",
          "id": 478198,
          "options_data": [],
          "solution_data": [
            {
              "id": 255925,
              "solution": "<p>Areas covered with concrete affect the availability of groundwater because concrete reduces the seepage of rainwater into the ground which leads to a reduction in the availability of groundwater.</p>"
            }
          ],
