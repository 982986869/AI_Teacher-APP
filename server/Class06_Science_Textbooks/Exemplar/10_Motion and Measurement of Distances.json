        },
        {
          "question": "<p>Three students measured the length of a corridor and reported their measurements. The values of their measurements were different. What could be the reason for difference in their measurements? (Mention any three)</p>",
          "id": 315437,
          "options_data": [],
          "solution_data": [
            {
              "id": 203127,
              "solution": "<p>Some of the reasons for the difference in their measurement could be</p>\n\n<ol start=\"1\" style=\"list-style-type: lower-roman;\">\n\t<li>Different measuring devices were used.</li>\n\t<li>The smallest length that could be&nbsp;measured by different devices may be different.</li>\n\t<li>The measurement may not be along the shortest length in all three cases.</li>\n\t<li>The end of the corridor may not be easily accessible.</li>\n\t<li>The measuring devices may be faulty (not standardised).</li>\n</ol>"
            }
          ],
          "num_solutions_data": [],
