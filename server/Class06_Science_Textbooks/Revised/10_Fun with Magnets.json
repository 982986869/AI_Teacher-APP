          "order": 3,
          "sub_order": null,
          "name": "3"
        },
        {
          "question": "<p>Column I&nbsp;shows different positions in which one pole of a magnet is placed near that of the other. Column II indicates the resulting action between them for each situation.</p>\r\n\r\n<table border=\"1\" cellpadding=\"3\" cellspacing=\"0\" style=\"width:100%;\">\r\n\t<tbody>\r\n\t\t<tr>\r\n\t\t\t<td style=\"text-align: center;\"><strong>Column i</strong></td>\r\n\t\t\t<td style=\"text-align: center;\"><strong>Column ii</strong></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>N - N</td>\r\n\t\t\t<td>_________</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>N - _________</td>\r\n\t\t\t<td>Attraction</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>S - N</td>\r\n\t\t\t<td>_________</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>_________ - S</td>\r\n\t\t\t<td>Repulsion</td>\r\n\t\t</tr>\r\n\t</tbody>\r\n</table>",
          "id": 477507,
          "options_data": [],
          "solution_data": [
            {
              "id": 255264,
              "solution": "<table border=\"1\" cellpadding=\"3\" cellspacing=\"0\" style=\"width:100%;\">\r\n\t<tbody>\r\n\t\t<tr>\r\n\t\t\t<td style=\"text-align: center;\"><strong>Column i</strong></td>\r\n\t\t\t<td style=\"text-align: center;\"><strong>Column ii</strong></td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>N - N</td>\r\n\t\t\t<td>Repulsion like poles</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>N - S</td>\r\n\t\t\t<td>Attraction unlike poles</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>S - N</td>\r\n\t\t\t<td>Attraction unlike poles</td>\r\n\t\t</tr>\r\n\t\t<tr>\r\n\t\t\t<td>S - S</td>\r\n\t\t\t<td>Repulsion like poles</td>\r\n\t\t</tr>\r\n\t</tbody>\r\n</table>"
