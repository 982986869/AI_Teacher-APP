generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  email             String?             @unique
  phone             String?             @unique
  passwordHash      String?
  grade             String?
  provider          AuthProvider        @default(EMAIL)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  role              UserRole            @default(STUDENT)
  brainGymSessions  BrainGymSession[]
  doubtSessions     DoubtSession[]
  knowledge_sources knowledge_sources[]
  lessons           Lesson[]

  @@map("users")
}

model BrainGymSession {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  skill          String
  level          Int
  totalQuestions Int
  correctCount   Int
  wrongCount     Int
  score          Int
  xpEarned       Int
  timeTakenSec   Int      @default(0)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("brain_gym_sessions")
}

model Lesson {
  id                String         @id @default(uuid()) @db.Uuid
  userId            String         @db.Uuid
  topic             String
  subject           String
  chapter           String?        // resolved from the topic at generation time (concept resolver)
  gradeLevel        String
  lessonTitle       String
  estimatedDuration String
  summary           String
  keyTerms          String[]
  status            LessonStatus   @default(GENERATING)
  generationModel   String?
  generationTimeMs  Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  doubtSessions     DoubtSession[]
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slides            Slide[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("lessons")
}

model Slide {
  id               String     @id @default(uuid()) @db.Uuid
  lessonId         String     @db.Uuid
  slideNumber      Int
  slideTitle       String
  explanation      String
  narrationText    String
  visualType       VisualType
  visualData       Json
  animationSteps   Json?
  animationType    String?
  highlightTargets Json?
  subtitleChunks   String[]   @default([])
  visualSequence   Json?
  voiceCue         String?
  lesson           Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, slideNumber])
  @@index([lessonId])
  @@map("slides")
}

model DoubtSession {
  id        String    @id @default(uuid()) @db.Uuid
  lessonId  String    @db.Uuid
  userId    String    @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([lessonId, userId])
  @@map("doubt_sessions")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  doubtSessionId String       @db.Uuid
  role           MessageRole
  content        String
  slideIndex     Int?
  createdAt      DateTime     @default(now())
  doubtSession   DoubtSession @relation(fields: [doubtSessionId], references: [id], onDelete: Cascade)

  @@index([doubtSessionId, createdAt])
  @@map("messages")
}

model chapters {
  id          BigInt      @id @default(autoincrement())
  subject_id  BigInt
  name        String
  slug        String
  class_level Int         @default(11)
  position    Int         @default(0)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  subjects    subjects    @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sections    sections[]
  subtopics   subtopics[]

  @@unique([subject_id, class_level, slug])
  @@index([subject_id], map: "idx_chapters_subject")
  @@index([subject_id, class_level], map: "idx_chapters_subject_class")
}

model knowledge_chunks {
  id                String                 @id @db.Uuid
  sourceId          String                 @db.Uuid
  chunkIndex        Int
  content           String
  charCount         Int                    @default(0)
  embedding         Unsupported("vector")?
  metadata          Json?
  createdAt         DateTime               @default(now())
  knowledge_sources knowledge_sources      @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([embedding], map: "knowledge_chunks_embedding_hnsw_idx")
  @@index([sourceId])
}

model knowledge_sources {
  id               String             @id @db.Uuid
  title            String
  description      String?
  type             String
  subject          String?
  gradeLevel       String?
  originalFilename String?
  mimeType         String?
  charCount        Int                @default(0)
  chunkCount       Int                @default(0)
  status           KnowledgeStatus    @default(PROCESSING)
  uploadedById     String             @db.Uuid
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  knowledge_chunks knowledge_chunks[]
  users            User               @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([subject, gradeLevel])
  @@index([uploadedById])
}

model phone_otps {
  id         String     @id @db.Uuid
  phone      String
  otpHash    String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int        @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, createdAt])
}

model questions {
  id             BigInt   @id @default(autoincrement())
  section_id     BigInt
  q_number       String?
  year           String?
  question_html  String
  is_mcq         Boolean  @default(false)
  options        Json?
  correct_option String?
  solution_html  String?
  position       Int      @default(0)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  sections       sections @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([section_id], map: "idx_questions_section")
}

model section_types {
  key      String     @id
  label    String
  position Int        @default(0)
  sections sections[]
}

model sections {
  id            BigInt        @id @default(autoincrement())
  chapter_id    BigInt
  type_key      String
  position      Int           @default(0)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  notes         notes?
  questions     questions[]
  chapters      chapters      @relation(fields: [chapter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  section_types section_types @relation(fields: [type_key], references: [key], onDelete: NoAction, onUpdate: NoAction)

  @@unique([chapter_id, type_key])
  @@index([chapter_id], map: "idx_sections_chapter")
}

model subjects {
  id         BigInt     @id @default(autoincrement())
  name       String
  slug       String     @unique
  position   Int        @default(0)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  chapters   chapters[]
}

model exemplar_solutions {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject        String
  className      String
  chapter        String
  section        String
  qNumber        String
  text           String
  options        Json     @default("[]")
  solutionLabel  String
  solution       String
  questionImages Json     @default("[]")
  solutionImages Json     @default("[]")
  position       Int
  createdAt      DateTime @default(now())

  @@index([subject, className, chapter, position])
  @@map("exemplar_solutions")
}

model ncert_solutions {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  part         Int      @default(2)
  subject      String
  className    String   @default("Class 11")
  chapter      String
  sectionKey   String
  sectionLabel String
  html         String?
  chapterPos   Int      @default(0)
  position     Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([part, subject, className, chapter, position])
  @@map("ncert_solutions")
}

model concept_prereqs {
  concept_id String @db.Uuid
  prereq_id  String @db.Uuid

  @@id([concept_id, prereq_id])
}

model concepts {
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject   String
  chapter   String
  name      String
  slug      String
  position  Int                    @default(0)
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now()) @db.Timestamptz(6)

  @@unique([subject, chapter, name], map: "concepts_uq")
  @@index([subject, chapter], map: "concepts_subject_idx")
}

model lesson_progress {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @db.Uuid
  lessonId        String    @db.Uuid
  slidesTotal     Int       @default(0)
  lastSlideIndex  Int       @default(0)
  slidesCompleted Int       @default(0)
  completedAt     DateTime? @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([userId, lessonId], map: "lesson_progress_uq")
  @@index([userId], map: "lesson_progress_user_idx")
}

model mcq_questions {
  id                BigInt    @id @default(autoincrement())
  subtopic_id       BigInt
  source_id         BigInt?
  question_html     String
  difficulty        String?
  options           Json
  correct_option_id BigInt?
  explanation_html  String?
  position          Int       @default(0)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  subtopics         subtopics @relation(fields: [subtopic_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([subtopic_id], map: "idx_mcq_questions_subtopic")
}

model mock_test_attempts {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?    @db.Uuid
  test_id        Int
  answers        Json       @default("{}")
  total          Int        @default(0)
  attempted      Int        @default(0)
  correct_count  Int        @default(0)
  wrong_count    Int        @default(0)
  score          Int        @default(0)
  time_taken_sec Int        @default(0)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  mock_tests     mock_tests @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([test_id], map: "mock_test_attempts_test_idx")
  @@index([user_id, created_at(sort: Desc)], map: "mock_test_attempts_user_idx")
}

model mock_test_questions {
  id                   Int        @id
  test_id              Int
  order_index          Int
  section_name         String?
  section_id           Int?
  question             String
  question_raw         String?
  options              Json
  correct_option_ids   Json       @default("[]")
  correct_option_texts Json       @default("[]")
  correct_index        Int?
  explanation          String?
  mock_tests           mock_tests @relation(fields: [test_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([test_id, order_index], map: "mock_test_questions_test_idx")
}

model mock_tests {
  id                  Int                   @id
  subject             String                @default("Physics")
  name                String
  category_full_name  String?
  duration_min        Int?
  no_of_questions     Int?
  instruction         String?
  section_count       Int                   @default(0)
  question_count      Int                   @default(0)
  source_extracted_at String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  mock_test_attempts  mock_test_attempts[]
  mock_test_questions mock_test_questions[]
}

model notes {
  id         BigInt   @id @default(autoincrement())
  section_id BigInt   @unique
  intro      String?
  blocks     Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  sections   sections @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([section_id], map: "idx_notes_section")
}

model student_concepts {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @db.Uuid
  concept_id    String   @db.Uuid
  mastery       Decimal  @default(0) @db.Decimal
  confidence    Decimal  @default(0) @db.Decimal
  weakness      Decimal  @default(0) @db.Decimal
  evidenceCount Int      @default(0)
  quizCorrect   Int      @default(0)
  quizTotal     Int      @default(0)
  doubts        Int      @default(0)
  recentFails   Int      @default(0)
  speedScore     Float    @default(0) // 0..1 rolling answer-speed (lifecycle engine)
  retentionScore Float    @default(0) // 0..1 retention at last practice (decays on read)
  streak         Int      @default(0) // consecutive correct answers on this concept
  revisionCount  Int      @default(0) // times surfaced as scheduled revision
  lastSeen      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @db.Timestamptz(6)

  @@unique([userId, concept_id], map: "student_concepts_uq")
  @@index([userId], map: "student_concepts_user_idx")
}

model mistake_book {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid
  itemKey       String    // questionId or 'seed:<seedId>' — dedup key
  source        String    @default("braingym") // braingym | homework | doubt
  questionId    String?   @db.Uuid
  seedId        String?
  subject       String    @default("Mental Math")
  chapter       String    @default("")
  concept       String    @default("")
  category      String?
  grade         String?
  difficulty    String?
  questionText  String    @default("")
  studentAnswer String?
  correctAnswer String?
  explanation   String    @default("")
  status        String    @default("unresolved") // unresolved | resolved
  timesWrong    Int       @default(1)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  lastWrongAt   DateTime  @default(now()) @db.Timestamptz(6)
  resolvedAt    DateTime? @db.Timestamptz(6)

  @@unique([userId, itemKey], map: "mistake_book_uq")
  @@index([userId, status, lastWrongAt(sort: Desc)], map: "mistake_book_open_idx")
  @@index([userId, subject], map: "mistake_book_subj_idx")
}

model student_events {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  type      String
  subject   String?
  chapter   String?
  detail    Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([userId, createdAt], map: "student_events_user_idx")
}

model student_memory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  subject     String
  chapter     String   @default("")
  doubts      Int      @default(0)
  mistakes    Int      @default(0)
  quizCorrect Int      @default(0)
  quizTotal   Int      @default(0)
  lastSeen    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @db.Timestamptz(6)

  @@unique([userId, subject, chapter], map: "student_memory_uq")
  @@index([userId, subject], map: "student_memory_user_idx")
}

model subtopics {
  id            BigInt          @id @default(autoincrement())
  chapter_id    BigInt
  name          String
  position      Int             @default(0)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  mcq_questions mcq_questions[]
  chapters      chapters        @relation(fields: [chapter_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([chapter_id, name])
  @@index([chapter_id], map: "idx_subtopics_chapter")
}

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
}

enum LessonStatus {
  GENERATING
  READY
  FAILED
}

enum VisualType {
  DIAGRAM
  CHART
  EXAMPLE
  ANALOGY
  FORMULA
  NONE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum KnowledgeStatus {
  PROCESSING
  READY
  FAILED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

// ─── BrainGym Adaptive Question Intelligence ────────────────────────────────
// Seed questions (the original 400) stay client-side as the offline bank.
// These tables hold the continuously-grown AI bank, per-student mastery,
// attempt history, generation audit trail, and vector signatures for dedup.

model generated_questions {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category              String                // reasoning | application | understanding | fluency
  grade                 String                // canonical class, e.g. "Class 9" — HARD guardrail
  subject               String                @default("Mental Math")
  chapter               String                @default("")
  topic                 String                @default("")
  concept               String                @default("")
  difficulty            String                // easy | medium | hard | challenge (WITHIN the grade)
  level                 Int                   // 1..3 served bucket (challenge maps to 3) for the numeric quiz
  questionText          String
  answer                String                // canonical correct answer (string form)
  answerValue           Float?                // numeric form when applicable (numeric keypad quiz)
  options               Json                  @default("[]") // 4 MCQ options (future MCQ UI)
  correctOption         Int                   @default(0)    // index into options
  explanation           String                @default("")
  hints                 String[]              @default([])
  bloomLevel            String                @default("understand")
  estimatedTimeSec      Int                   @default(30)
  qualityScore          Float                 @default(0)
  validationScore       Float                 @default(0)
  status                String                @default("ACTIVE") // ACTIVE | ARCHIVED | REJECTED | DRAFT
  isPrerequisite        Boolean               @default(false) // prereq revision from a lower class
  prereqGrade           String?               // the lower class a prereq revision targets
  parentQuestionId      String?               // seedId or generated_questions.id it was varied from
  generationPromptVersion String              @default("v1")
  llmModel              String                @default("")
  signature             String                // normalized hash of the question for fast dedup
  timesServed           Int                   @default(0)
  timesCorrect          Int                   @default(0)
  timesWrong            Int                   @default(0)
  ambiguityFlag         Boolean               @default(false)
  archivedReason        String?
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @default(now()) @db.Timestamptz(6)
  embedding             question_embeddings?
  attempts              question_attempts[]

  @@unique([grade, subject, signature], map: "gen_q_grade_subject_sig_uq") // dedup race guard
  @@index([grade, subject, category, difficulty, status], map: "gen_q_lookup_idx")
  @@index([status, qualityScore(sort: Desc)], map: "gen_q_quality_idx")
  @@map("generated_questions")
}

model question_embeddings {
  questionId String                 @id @db.Uuid
  embedding  Unsupported("vector")?
  model      String                 @default("voyage-3.5-lite")
  createdAt  DateTime               @default(now()) @db.Timestamptz(6)
  question   generated_questions    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([embedding], map: "question_embeddings_hnsw_idx")
  @@map("question_embeddings")
}

model question_attempts {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String               @db.Uuid
  questionId  String?              @db.Uuid // null for seed questions
  seedId      String?              // set when the served question came from the offline seed bank
  source      String               // seed | generated
  category    String
  grade       String?
  subject     String               @default("Mental Math")
  difficulty  String?
  isCorrect   Boolean
  answerGiven String?
  timeMs      Int                  @default(0)
  sessionId   String?              @db.Uuid
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)
  question    generated_questions? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)], map: "q_attempts_user_idx")
  @@index([userId, questionId], map: "q_attempts_user_question_idx")
  @@index([userId, seedId], map: "q_attempts_user_seed_idx")
  @@map("question_attempts")
}

model student_mastery {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String   @db.Uuid
  category             String
  subject              String   @default("Mental Math")
  grade                String   // the class the student is in (mastery is tracked within-class)
  attempts             Int      @default(0)
  correct              Int      @default(0)
  accuracy             Float    @default(0) // rolling, 0..1
  streak               Int      @default(0) // consecutive correct answers
  masteryScore         Float    @default(0) // 0..1
  currentDifficulty    String   @default("easy") // easy | medium | hard | challenge
  hiAccuracySessions   Int      @default(0) // consecutive high-accuracy sessions (for challenge promotion)
  recentFails          Int      @default(0) // for automatic struggle downgrade
  lastSeen             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @db.Timestamptz(6)

  @@unique([userId, category, subject], map: "student_mastery_uq")
  @@index([userId], map: "student_mastery_user_idx")
  @@map("student_mastery")
}

model generation_history {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String?          @db.Uuid // null for background/batch runs
  category           String
  grade              String
  subject            String           @default("Mental Math")
  difficulty         String
  requested          Int              @default(0)
  generated          Int              @default(0)
  accepted           Int              @default(0)
  rejectedValidation Int              @default(0)
  rejectedDuplicate  Int              @default(0)
  rejectedGuardrail  Int              @default(0)
  promptVersion      String           @default("v1")
  llmModel           String           @default("")
  durationMs         Int              @default(0)
  trigger            String           @default("on_demand") // on_demand | background | batch
  status             String           @default("SUCCESS") // SUCCESS | PARTIAL | FAILED
  error              String?
  createdAt          DateTime         @default(now()) @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "gen_history_time_idx")
  @@index([category, grade], map: "gen_history_cat_grade_idx")
  @@map("generation_history")
}

