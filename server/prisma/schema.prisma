generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum KnowledgeStatus {
  PROCESSING
  READY
  FAILED
}

enum LessonStatus {
  GENERATING
  READY
  FAILED
}

// DIAGRAM:  { description: string, label: string, components: string[] }
// CHART:    { chartType: string, data: { labels: string[], values: number[] }, xAxis: string, yAxis: string }
// EXAMPLE:  { scenario: string, steps: string[] }
// ANALOGY:  { realWorldObject: string, comparison: string }
// FORMULA:  { formula: string, variables: { symbol: string, meaning: string }[], explanation: string }
// NONE:     {}
enum VisualType {
  DIAGRAM
  CHART
  EXAMPLE
  ANALOGY
  FORMULA
  NONE
}

enum MessageRole {
  USER
  ASSISTANT
}

enum OtpPurpose {
  LOGIN
  SIGNUP
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  email        String?      @unique
  phone        String?      @unique
  passwordHash String?
  grade        String?
  role         UserRole     @default(STUDENT)
  provider     AuthProvider @default(EMAIL)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lessons          Lesson[]
  doubtSessions    DoubtSession[]
  knowledgeSources KnowledgeSource[]

  @@map("users")
}

// One-time passwords for phone auth. The plain OTP is NEVER stored — only its
// bcrypt hash. Old OTPs are consumed when a new one is requested.
model PhoneOtp {
  id         String     @id @default(uuid()) @db.Uuid
  phone      String
  otpHash    String
  purpose    OtpPurpose
  expiresAt  DateTime
  attempts   Int        @default(0)
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, createdAt])
  @@map("phone_otps")
}

// ─── Knowledge (RAG) ──────────────────────────────────────────────────────────

model KnowledgeSource {
  id               String          @id @default(uuid()) @db.Uuid
  title            String
  description      String?
  type             String // 'text' | 'markdown'
  subject          String?
  gradeLevel       String?
  originalFilename String?
  mimeType         String?
  charCount        Int             @default(0)
  chunkCount       Int             @default(0)
  status           KnowledgeStatus @default(PROCESSING)
  uploadedById     String          @db.Uuid

  uploadedBy User             @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  chunks     KnowledgeChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject, gradeLevel])
  @@index([uploadedById])
  @@map("knowledge_sources")
}

model KnowledgeChunk {
  id         String   @id @default(uuid()) @db.Uuid
  sourceId   String   @db.Uuid
  chunkIndex Int
  content    String   @db.Text
  charCount  Int      @default(0)
  // pgvector column — Prisma cannot read/write this directly, so inserts and
  // similarity search are done via raw SQL ($executeRaw / $queryRaw).
  // Dimension MUST match EMBEDDING_DIM (Voyage voyage-3.5 = 1024).
  embedding  Unsupported("vector(1024)")?
  metadata   Json?
  createdAt  DateTime @default(now())

  source KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([sourceId])
  @@map("knowledge_chunks")
}

model Lesson {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  topic             String
  subject           String
  gradeLevel        String
  lessonTitle       String
  estimatedDuration String
  summary           String       @db.Text
  keyTerms          String[]
  status            LessonStatus @default(GENERATING)
  generationModel   String?
  generationTimeMs  Int?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slides        Slide[]
  doubtSessions DoubtSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@map("lessons")
}

// Visual data shape by visualType (stored as JSON):
// DIAGRAM:  { description: string, label: string, components: string[] }
// CHART:    { chartType: string, data: { labels: string[], values: number[] }, xAxis: string, yAxis: string }
// EXAMPLE:  { scenario: string, steps: string[] }
// ANALOGY:  { realWorldObject: string, comparison: string }
// FORMULA:  { formula: string, variables: { symbol: string, meaning: string }[], explanation: string }
// NONE:     {}
model Slide {
  id            String     @id @default(uuid()) @db.Uuid
  lessonId      String     @db.Uuid
  slideNumber   Int
  slideTitle    String
  explanation   String     @db.Text
  narrationText String     @db.Text
  visualType    VisualType
  visualData    Json

  // ─── Animation metadata (optional; frontend falls back to the fields above) ──
  // animationType:    "FADE_IN" | "STEP_REVEAL" | "BUILD_UP" | "TYPEWRITER" | "ZOOM" | "NONE"
  // animationSteps:   [{ order: int, action: string, target: string, durationMs: int, description: string }]
  // subtitleChunks:   narrationText split into short caption-sized phrases (TTS-synced)
  // visualSequence:   [{ order: int, element: string, appearAtMs: int }]
  // highlightTargets: [{ ref: string, label: string, emphasis: string }]
  // voiceCue:         short delivery hint for narration tone
  animationType    String?
  animationSteps   Json?
  subtitleChunks   String[]  @default([])
  visualSequence   Json?
  highlightTargets Json?
  voiceCue         String?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, slideNumber])
  @@index([lessonId])
  @@map("slides")
}

model DoubtSession {
  id       String @id @default(uuid()) @db.Uuid
  lessonId String @db.Uuid
  userId   String @db.Uuid

  lesson   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId, userId])
  @@map("doubt_sessions")
}

model Message {
  id             String      @id @default(uuid()) @db.Uuid
  doubtSessionId String      @db.Uuid
  role           MessageRole
  content        String      @db.Text
  slideIndex     Int?
  createdAt      DateTime    @default(now())

  doubtSession DoubtSession @relation(fields: [doubtSessionId], references: [id], onDelete: Cascade)

  @@index([doubtSessionId, createdAt])
  @@map("messages")
}
