# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/ailernova_db"

# ─── Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-hex-string
JWT_EXPIRES_IN=7d

# ─── AI Provider ──────────────────────────────────────────
# Which provider to use: "anthropic" (only supported option for now)
AI_PROVIDER=anthropic

# Master switch for AI calls (lessons, doubts, AND BrainGym question generation).
#   MOCK_AI=true  → NO Claude calls. BrainGym uses its deterministic, grade-safe
#                   fallback generator. Lessons/doubts use mock responses.
#   MOCK_AI=false → real Claude is used WHEN ANTHROPIC_API_KEY is also set.
MOCK_AI=true

# Your Anthropic API key from https://console.anthropic.com
# BrainGym AI generation is ENABLED only when: MOCK_AI=false AND this key is set
# AND AI_PROVIDER=anthropic. Otherwise BrainGym silently uses the fallback
# generator (questions are still valid, grade-safe and numeric — just templated).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model for lesson generation (high-quality, structured output)
AI_LESSON_MODEL=claude-opus-4-8

# Model for doubt Q&A (fast, conversational)
AI_DOUBT_MODEL=claude-haiku-4-5

# Optional: dedicated model for BrainGym question generation. Falls back to
# AI_DOUBT_MODEL then AI_LESSON_MODEL when unset.
# AI_KNOWLEDGE_MODEL=claude-haiku-4-5

# ─── Embeddings (BrainGym duplicate detection + RAG) ──────
# Voyage AI key. When set, generated BrainGym questions get a 1024-dim vector
# stored in question_embeddings (used for semantic duplicate detection).
# Optional — signature + token-overlap dedup works without it.
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3.5-lite
EMBEDDING_DIM=1024

# ─── How to enable REAL BrainGym AI generation ────────────
# 1. Set MOCK_AI=false
# 2. Set ANTHROPIC_API_KEY=sk-ant-...
# 3. (optional) Set VOYAGE_API_KEY for semantic dedup
# 4. Restart the server. Server logs will then show origins: { ai_generated: N }
#    instead of { fallback_generated: N }.

# ─── Image storage (Supabase Storage) ────────────────────
# Powers admin content-image upload (question / option diagrams). The uploaded
# image's public URL is embedded as <img> in the question/option HTML.
# Setup once:
#   1. Supabase dashboard → Storage → New bucket → name it "content-images" → PUBLIC.
#   2. Project Settings → API → copy the URL and the service_role key below.
# When these are unset, image upload returns a clear "not configured" error and
# every other feature keeps working.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=content-images

# ─── Teacher voice (OpenAI TTS) ───────────────────────────
# All narration streams from /api/tts. Unset ⇒ the app silently falls back to
# on-device Expo Speech, which sounds noticeably worse.
OPENAI_API_KEY=

# ─── Phone OTP login (MSG91) — NOT WIRED UP YET ───────────
# config.sms is read by nothing today: there is no OTP route or controller in
# server/src. Auth is email+password only. These keys are here for when phone
# login is actually built — leaving them empty changes no behaviour.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_OTP_EXPIRY_MIN=5

# ─── RAG retrieval tuning ─────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.2

# ─── Tester allowlist ─────────────────────────────────────
# Comma-separated emails that may switch between every class from one login.
# The only case where a client-supplied ?class= is trusted — keep it empty in
# a real production deploy unless you intend it.
TESTER_EMAILS=

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces). Unset ⇒ "*".
# Note: the native app and the admin portal (Next.js server-side rewrite) both
# send no Origin header, so this only constrains browsers hitting the API directly.
# Expo Go on Android: exp://192.168.x.x:8081
# Expo Go on iOS:     exp://192.168.x.x:19000
# Web:                http://localhost:19006
ALLOWED_ORIGINS=http://localhost:19006,exp://localhost:8081
